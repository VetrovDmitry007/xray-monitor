# URL подписки/источника конфигурации Xray.
# Не указывай здесь реальный приватный URL в публичном репозитории.
xray_url=https://example.com/subscription-path

# Идентификатор устройства/клиента для запроса подписки.
# В текущем проекте переменная названа именно X-Hwid, поэтому оставлена для совместимости.
X-Hwid=00000000-0000-0000-0000-000000000000

# Локальный порт SOCKS5, который поднимает Xray-клиент.
port_client_xray=1080

# Путь к бинарному файлу Xray.
# Linux/macOS пример:
bin_xray=./xray/xray
# Windows пример:
# bin_xray=D:\\Python_2\\xray-monitor\\xray\\xray.exe

# Путь к основному конфигу Xray на сервере/в systemd-окружении.
config_xray=/usr/local/etc/xray/config.json

# URL локального SOCKS5-прокси для Telegram/aiogram.
TELEGRAM_PROXY_URL=socks5://127.0.0.1:1080
